{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "createVnet": {
      "value": "${AZURE_CREATE_VNET=false}"
    },
    "vnetResourceGroupName": {
      "value": "${AZURE_VNET_RESOURCE_GROUP_NAME=}"
    },
    "vnetName": {
      "value": "${AZURE_VNET_NAME=}"
    },
    "vnetAddressPrefix": {
      "value": "${AZURE_VNET_ADDRESS_PREFIX=10.0.0.0/24}"
    },
    "acaSubnetAddressPrefix": {
      "value": "${AZURE_ACA_SUBNET_ADDRESS_PREFIX=10.0.0.0/25}"
    },
    "privateEndpointSubnetAddressPrefix": {
      "value": "${AZURE_PE_SUBNET_ADDRESS_PREFIX=10.0.0.128/25}"
    },
    "sqlDatabaseName": {
      "value": "${AZURE_SQL_DATABASE_NAME=appdb}"
    },
    "sqlEntraAdminObjectId": {
      "value": "${AZURE_SQL_ENTRA_ADMIN_OBJECT_ID}"
    },
    "sqlEntraAdminLogin": {
      "value": "${AZURE_SQL_ENTRA_ADMIN_LOGIN}"
    },
    "sqlAdminLogin": {
      "value": "${AZURE_SQL_ADMIN_LOGIN}"
    },
    "sqlAdminPassword": {
      "value": "${AZURE_SQL_ADMIN_PASSWORD}"
    },
    "jumpboxAdminUsername": {
      "value": "${AZURE_JUMPBOX_ADMIN_USERNAME=azureadmin}"
    },
    "jumpboxAdminPassword": {
      "value": "${AZURE_JUMPBOX_ADMIN_PASSWORD}"
    }
  }
}
